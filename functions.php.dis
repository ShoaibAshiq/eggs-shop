function getrecentopics(){
    global $post;
    $terms = wp_get_post_terms( $post->ID, 'question');
    $args = array(
	'numberposts' => -1,
	'offset' => 0,
	'category' => 0,
	'orderby' => 'post_date',
	'order' => 'DESC',
	'include' => '',
	'exclude' => '',
	'meta_key' => '',
	'meta_value' =>'',
	'post_type' => 'topics',
	'tax_query' => array(
    'relation' => 'AND',
    array(
        'taxonomy' => 'question',
        'field'    => 'ID',
        'terms'    => $terms[0]->term_id
         )
    ),
	'post_status' => 'publish',
	'suppress_filters' => true
);
?>
   <h2 class='widgettitle'><a href="https://eggstime.com/topic/" style="color:#219FD1 !important;">Topics</a></h2>
<ul class='sidebar_topicslist'>

<?php
    global $wp;

    $getcurrenturl = home_url($wp->request).'/';
	$recent_posts = wp_get_recent_posts( $args, ARRAY_A );
	if($recent_posts){
	foreach( $recent_posts as $recent ){
	    if($getcurrenturl==get_permalink($recent["ID"])){
	        $classtopic='active';
	    }
	    else{
	        $classtopic='';
	    }
		echo '<li><a class="'.$classtopic.'" href="' . get_permalink($recent["ID"]) . '">' .   $recent["post_title"].'</a> </li> ';
	    }
	   
	} else echo "Nothing Found"; 
	wp_reset_query();
?>
</ul>
<?php
}
add_shortcode('getrecentopics','getrecentopics');

function get_topics_taxonomies() {
$terms = get_terms([
    'taxonomy' => 'question',
    'hide_empty' => false,
    //'orderby' => 'post_date',
    'order' => 'ASC',
]);
//print_r($terms);?>
 <h2 class='widgettitle'><a href="https://eggstime.com/topic/" style="color:#219FD1 !important;">Products & Brands</a></h2>
<ul class='sidebar_questionlist'>

<?php
$getcurrentlink= get_queried_object();
 $getcurrentlink = site_url().'/question/'.$getcurrentlink->slug.'/';
foreach ($terms  as $taxonomy ) {
    $term_link = get_term_link( $taxonomy );
     if($getcurrentlink==$term_link){
	        $classquestion='active';
	    }
	    else{
	        $classquestion='';
	    }
    echo '<li><a class="'.$classquestion.'" href="'.$term_link.'">' . $taxonomy->name . '</a></li>';
  }
  echo "</ul>";
}
add_shortcode('get_topics_taxonomies','get_topics_taxonomies');



